# OpsKG 环境变量配置
# 复制此文件为 .env 并修改配置: cp .env.example .env
# 完整字段说明见 backend/app/config.py

# ────────── 运行环境 ──────────
ENV=dev
LOG_LEVEL=INFO

# ────────── LLM 后端（三选一）──────────
# 可选值: openai_compat | ollama | vllm
LLM_BACKEND=openai_compat
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096

# DeepSeek / OpenAI 兼容（推荐，云端）
# 获取 API Key: https://platform.deepseek.com/api_keys
OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
OPENAI_COMPAT_API_KEY=sk-your-key-here
OPENAI_COMPAT_MODEL=deepseek-chat

# Ollama（本地，免费）
# 先安装 Ollama (https://ollama.com) 并下载模型: ollama pull qwen2.5:7b
#
# ⚠️ Ollama OpenAI 兼容端点：OpenAI SDK 要求 base_url 包含 /v1 后缀
#   本地原生部署：http://localhost:11434/v1
#   Docker 容器内访问宿主：http://host.docker.internal:11434/v1
#
# ⚠️ Docker 部署 + 宿主 Ollama 场景（WSL2/Win/Linux 均适用）：
#   1. 容器内 localhost 指向容器自身，访问不到宿主 Ollama，必须用 host.docker.internal
#   2. Win 版 Ollama 默认只监听 127.0.0.1，容器无法访问，需设置系统环境变量：
#        OLLAMA_HOST=0.0.0.0:11434
#      设置后重启 Ollama 服务（任务栏退出再启动）
#   3. docker-compose.yml 已添加 extra_hosts: host.docker.internal:host-gateway
#      WSL2 用 Docker Desktop 时也兼容（Docker Desktop 默认支持该主机名）
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# vLLM（本地，需 GPU）
# 同 Ollama，Docker 部署时用 host.docker.internal 访问宿主 vLLM
VLLM_BASE_URL=http://host.docker.internal:8000
VLLM_MODEL=Qwen2.5-14B-Instruct

# ────────── Embedding（向量检索，可选）──────────
# 留空则关闭向量检索，搜索退化为纯关键词
EMBEDDING_MODEL=
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=16

# ────────── Neo4j（可选，缺失时图功能降级）──────────
# Docker 部署用 bolt://neo4j:7687；本地部署用 bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ────────── SSRF 防护（开发环境）──────────
# 设置 1 允许后端访问 localhost（用于本地 Ollama/Neo4j 测试连通）
# 生产环境请勿开启，避免 SSRF 风险
OPSKG_ALLOW_LOOPBACK_URLS=

# ────────── 认证 ──────────
# 留空关闭认证（dev 模式，所有 API 直接可访问，前端无需登录）
# 生产环境请设置随机 Token 或使用 bootstrap admin
OPSKG_API_TOKEN=

# Alertmanager webhook 入站 token（P2-2.5）
# 专用于 POST /events/ingest/alertmanager 端点
# 留空则回退到 OPSKG_API_TOKEN；二者皆空则 dev 模式放行
# 用途：Alertmanager webhook_configs.url 中携带 ?token=xxx
# 示例：https://opskg.example.com/events/ingest/alertmanager?token=your-token-here
OPSKG_ALERTMANAGER_INGEST_TOKEN=

# Bootstrap admin（首次启动自动创建的管理员账号）
# 生产环境务必修改默认密码！
OPSKG_BOOTSTRAP_ADMIN_USER=admin
OPSKG_BOOTSTRAP_ADMIN_PASSWORD=admin

# ────────── 抽取门控 ──────────
# 置信度 >= CONFIDENCE_AUTO 自动接受；>= CONFIDENCE_REVIEW 进审查队列；< CONFIDENCE_REVIEW 丢弃
CONFIDENCE_AUTO=0.85
CONFIDENCE_REVIEW=0.60

# ────────── 知识编译（权威性评分权重）──────────
AUTHORITY_SOURCE_WEIGHT=0.5
AUTHORITY_RECENCY_WEIGHT=0.3
AUTHORITY_CONSENSUS_WEIGHT=0.2

# ────────── 文档生成 ──────────
DOC_GEN_MAX_ITER=3
DOC_GEN_TOKEN_SOFT=120000
DOC_GEN_TOKEN_HARD=200000

# ────────── 可观测性（可选）──────────
# OpenTelemetry 分布式追踪（默认关闭，设为 1 启用）
OPSKG_TRACING_ENABLED=0
OPSKG_OTLP_ENDPOINT=
OPSKG_OTLP_SERVICE_NAME=opskg-backend

# ────────── HA 高可用（可选）──────────
# standalone: 单实例（默认）| replicated: 多实例 + 共享存储
OPSKG_DEPLOYMENT_MODE=standalone
OPSKG_INSTANCE_ID=

# ────────── Docker 部署专用 ──────────
# 镜像版本（docker-compose.yml 中引用，与 ghcr.io 标签对应）
OPSKG_VERSION=0.0.1
# 宿主端口（默认 9981，如占用可改为 80/8080 等）
OPSKG_PORT=9981
# uvicorn worker 数（默认 2，按 CPU 核数调整）
OPSKG_UVICORN_WORKERS=2
