# Git
.git
.gitignore
.github

# Python 缓存与虚拟环境
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
.pytest_cache
.ruff_cache
.mypy_cache
backend/.venv
backend/venv
.venv
venv

# Node 缓存与构建产物（镜像内重新构建）
frontend/node_modules
frontend/dist

# 数据与日志（不应进入镜像）
backend/data/
backend/data
data
*.log
*.db
*.sqlite

# 文档（不应进入镜像）
docs/
*.md

# 测试代码（不应进入镜像）
backend/tests/
scripts/

# 部署清单（K8s yaml 不应进入镜像，但保留 deploy/docker/ 供 Dockerfile COPY）
deploy/k8s/

# 环境变量（敏感信息不应进入镜像）
.env
.env.*
*.env

# IDE
.vscode
.idea
*.swp
*.swo

# CI/测试报告
coverage
.coverage
htmlcov
test-results

# 文档构建
site

# 备份
*.bak
*.tar.gz
data/backups
