# OpsKG 敏感配置 Secret 模板（S13-3 K8s 部署）
#
# 警告：本文件仅作模板，请勿将真实密钥提交到版本控制！
# 部署前请使用以下任一方式生成真实 Secret：
#
# 方式 1（推荐，从字面值生成）：
#   kubectl create secret generic opskg-secret -n opskg \
#     --from-literal=NEO4J_AUTH='neo4j/your-real-password' \
#     --from-literal=OPENAI_COMPAT_API_KEY='sk-xxx' \
#     --from-literal=OPSKG_API_TOKEN='your-api-token' \
#     --from-literal=OPSKG_BOOTSTRAP_ADMIN_USER='admin' \
#     --from-literal=OPSKG_BOOTSTRAP_ADMIN_PASSWORD='change-me-in-production' \
#     --from-literal=OIDC_PROVIDERS='[{"name":"google",...}]' \
#     --from-literal=SAML_PROVIDERS='[...]' \
#     --from-literal=LDAP_PROVIDERS='[...]'
#
# 方式 2（从文件生成，便于 SAML 证书等长文本）：
#   1. 复制本文件为 secret.local.yaml（已被 .gitignore 忽略）
#   2. 填入真实值
#   3. kubectl apply -f secret.local.yaml
#   4. 删除 secret.local.yaml
#
# 方式 3（Sealed Secrets / External Secrets，生产推荐）：
#   使用 bitnami/sealed-secrets 或 external-secrets/external-secrets
#   将密钥加密后纳入 GitOps
apiVersion: v1
kind: Secret
metadata:
  name: opskg-secret
  namespace: opskg
  labels:
    app.kubernetes.io/name: opskg
    app.kubernetes.io/component: secret
type: Opaque
stringData:
  # ── Neo4j（格式：neo4j/<password>，与官方镜像一致）──
  NEO4J_AUTH: "neo4j/CHANGE_ME"

  # ── LLM API Key（OPENAI_COMPAT 模式）──
  OPENAI_COMPAT_API_KEY: "CHANGE_ME"

  # ── 后端 API Token（留空关闭认证）──
  OPSKG_API_TOKEN: ""

  # ── 引导管理员账号（首次启动时创建）──
  OPSKG_BOOTSTRAP_ADMIN_USER: "admin"
  OPSKG_BOOTSTRAP_ADMIN_PASSWORD: "CHANGE_ME"

  # ── OIDC / SAML / LDAP 提供者配置（JSON 字符串）──
  # 留空则关闭对应 SSO
  OIDC_PROVIDERS: ""
  SAML_PROVIDERS: ""
  LDAP_PROVIDERS: ""
